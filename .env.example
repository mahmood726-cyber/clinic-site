# London Cardiology Clinic — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.

# PostgreSQL
POSTGRES_PASSWORD=generate-a-strong-password-here

# Cal.com secrets (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=
CALENDSO_ENCRYPTION_KEY=

# Stripe (from stripe.com dashboard)
STRIPE_API_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_live_...

# Email SMTP (Proton Mail Bridge or other SMTP)
EMAIL_SERVER_HOST=127.0.0.1
EMAIL_SERVER_PORT=1025
EMAIL_SERVER_USER=drmahmoodclinic@pm.me
EMAIL_SERVER_PASSWORD=
